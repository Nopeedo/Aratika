# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# stripe cli (local dev binary)
/stripe.exe

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Scraped source-capture working files for draft-positions.mjs (not source code)
scripts/.cache/

# Internal working docs — keep local, never publish
*.xlsx
docs/*.docx
docs/~$*

# Governance/funding doc generators — keep local, never publish
scripts/build-trust-deed.cjs
scripts/build-board-pack.cjs
scripts/build-eoi.cjs
scripts/build-ec-enquiry.cjs
scripts/build-funder-targets.cjs
scripts/build-ec-compliance.cjs
*.bak
scripts/build-call-notes.cjs
scripts/build-research-concept.cjs
